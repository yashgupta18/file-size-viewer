{
  "name": "file-size-viewer",
  "displayName": "file-size-viewer",
  "description": "View file size of each file in your project",
  "version": "0.1.0",
  "publisher": "yash-c71e123f-dc39-4c65-82bf-a7e6c9278f10",
  "engines": {
    "vscode": "^1.97.0"
  },
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/yashgupta18/file-size-viewer.git"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "fileDecorations": [
      {
        "scheme": "file",
        "provider": "fileSizeViewer"
      }
    ],
    "commands": [
      {
        "command": "fileSizeViewer.refresh",
        "title": "Refresh File Size Viewer"
      },
      {
        "command": "fileSizeViewer.copyFileSize",
        "title": "Copy File Size"
      },
      {
        "command": "fileSizeViewer.openLargestFile",
        "title": "Open Largest File in Folder"
      },
      {
        "command": "fileSizeViewer.showTopFiles",
        "title": "Show Top Files in Folder"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "fileSizeViewer.copyFileSize",
          "group": "fileSizeViewer@1",
          "when": "explorerResourceIsFolder || !explorerResourceIsFolder"
        },
        {
          "command": "fileSizeViewer.openLargestFile",
          "group": "fileSizeViewer@2",
          "when": "explorerResourceIsFolder"
        },
        {
          "command": "fileSizeViewer.showTopFiles",
          "group": "fileSizeViewer@3",
          "when": "explorerResourceIsFolder"
        }
      ]
    },
    "configuration": {
      "title": "File Size Viewer",
      "properties": {
        "fileSizeViewer.greenMaxBytes": {
          "type": "number",
          "default": 1048576,
          "minimum": 0,
          "description": "Maximum size (bytes) for the green band. Example: 1048576 = 1MB"
        },
        "fileSizeViewer.yellowMinBytes": {
          "type": "number",
          "default": 1048577,
          "minimum": 0,
          "description": "Minimum size (bytes) for the yellow band. Example: 1048577 = 1MB + 1 byte"
        },
        "fileSizeViewer.yellowMaxBytes": {
          "type": "number",
          "default": 104857600,
          "minimum": 0,
          "description": "Maximum size (bytes) for the yellow band. Example: 104857600 = 100MB"
        },
        "fileSizeViewer.redMinBytes": {
          "type": "number",
          "default": 104857601,
          "minimum": 0,
          "description": "Minimum size (bytes) for the red band. Example: 104857601 = 100MB + 1 byte"
        },
        "fileSizeViewer.excludePatterns": {
          "type": "array",
          "default": [
            "node_modules",
            ".git",
            "dist",
            "out",
            "build",
            ".vscode"
          ],
          "description": "Folders and files to exclude from size calculation. Supports folder names and glob patterns.",
          "items": {
            "type": "string"
          }
        },
        "fileSizeViewer.maxRecursionDepth": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 50,
          "description": "Maximum folder depth for recursive size calculation. Lower values improve performance in deep directory structures."
        },
        "fileSizeViewer.enableFolderSizeCalculation": {
          "type": "boolean",
          "default": true,
          "description": "Enable recursive folder size calculation. Disable this for very large repositories to improve performance."
        },
        "fileSizeViewer.enableCache": {
          "type": "boolean",
          "default": true,
          "description": "Enable caching of computed file/folder sizes for better performance. Cache is automatically invalidated on file changes."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.97.0",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^10.7.0",
    "typescript": "^6.0.3"
  }
}
